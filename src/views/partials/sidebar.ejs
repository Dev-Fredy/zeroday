<script>
  (function() {
    const overlay = document.querySelector('.jsSidebarOverlay');
    const sidebar = document.querySelector('.jsSidebar');
    const closeBtn = document.querySelector('.jsSidebarClose');
    
    // Hide sidebar initially
    if (overlay) {
      overlay.style.display = 'none';
    }
    
    // Open sidebar function (called from header)
    window.openSidebar = function() {
      if (overlay) {
        overlay.style.display = 'block';
        setTimeout(() => {
          overlay.classList.add('active');
          sidebar.classList.add('active');
          document.body.style.overflow = 'hidden';
        }, 10);
        
        // Update dashboard badge count if needed
        updateBadgeCount();
      }
    };
    
    // Close sidebar function
    function closeSidebar() {
      if (overlay) {
        overlay.classList.remove('active');
        sidebar.classList.remove('active');
        document.body.style.overflow = '';
        
        setTimeout(() => {
          overlay.style.display = 'none';
        }, 300);
      }
    }
    
    // Close button click
    if (closeBtn) {
      closeBtn.addEventListener('click', closeSidebar);
    }
    
    // Click outside to close
    if (overlay) {
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) {
          closeSidebar();
        }
      });
    }
    
    // Escape key to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay && overlay.style.display === 'block') {
        closeSidebar();
      }
    });
    
    // Highlight active link
    const currentPath = window.location.pathname;
    document.querySelectorAll('.nav-link').forEach(link => {
      const href = link.getAttribute('href');
      if (href && currentPath.includes(href) && href !== '/') {
        link.classList.add('active');
      } else if (href === '/' && currentPath === '/') {
        link.classList.add('active');
      }
    });
    
    // Update badge count (example - fetch from API)
    function updateBadgeCount() {
      const badge = document.getElementById('dashboardBadge');
      if (badge) {
        // You can fetch real count from API
        fetch('/api/notifications/count')
          .then(res => res.json())
          .then(data => {
            if (data.count > 0) {
              badge.textContent = data.count;
              badge.style.display = 'flex';
            } else {
              badge.style.display = 'none';
            }
          })
          .catch(() => {
            badge.style.display = 'none';
          });
      }
    }
    
    // Handle escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay && overlay.classList.contains('active')) {
        closeSidebar();
      }
    });
    
    // Swipe to close (mobile gesture)
    let touchStartX = 0;
    if (sidebar) {
      sidebar.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
      });
      
      sidebar.addEventListener('touchmove', (e) => {
        const touchX = e.touches[0].clientX;
        const diff = touchStartX - touchX;
        
        if (diff > 50) {
          closeSidebar();
        }
      });
    }
  })();
</script>