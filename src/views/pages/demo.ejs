<section class="wealth-canvas" x-data="wealthSimulator" x-init="initialize()">
  <div class="canvas-bg"></div>

  <div class="canvas-container">
    <div class="config-panel">
      <div class="strategy-card">
        <div class="card-header">
          <div class="header-left">
            <span class="header-icon">🎯</span>
            <h3>Investment Strategy</h3>
          </div>
          <div
            class="strategy-badge"
            :class="strategy"
            x-text="strategyLabel"
          ></div>
        </div>

        <div class="strategy-selector">
          <div
            class="strategy-option"
            :class="{ active: strategy === 'safe' }"
            @click="setStrategy('safe')"
          >
            <div class="option-icon">🛡️</div>
            <div class="option-content">
              <h4>Safe Saver</h4>
              <p>Capital preservation</p>
            </div>
            <div class="option-indicator"></div>
          </div>

          <div
            class="strategy-option"
            :class="{ active: strategy === 'balanced' }"
            @click="setStrategy('balanced')"
          >
            <div class="option-icon">⚖️</div>
            <div class="option-content">
              <h4>Balanced</h4>
              <p>Moderate growth</p>
            </div>
            <div class="option-indicator"></div>
          </div>

          <div
            class="strategy-option"
            :class="{ active: strategy === 'aggressive' }"
            @click="setStrategy('aggressive')"
          >
            <div class="option-icon">🚀</div>
            <div class="option-content">
              <h4>Aggressive</h4>
              <p>Maximum returns</p>
            </div>
            <div class="option-indicator"></div>
          </div>
        </div>

        <div class="risk-profile">
          <div class="risk-header">
            <span>Risk Profile</span>
            <span class="risk-value" x-text="riskLabel"></span>
          </div>
          <div class="risk-bar-container">
            <div class="risk-bar-bg"></div>
            <div class="risk-bar-fill" :style="`width: ${riskLevel}%`"></div>
            <div class="risk-markers">
              <span>Low</span>
              <span>Moderate</span>
              <span>High</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Input Parameters -->
      <div class="params-section">
        <div class="section-title">
          <span>Simulation Parameters</span>
          <button class="reset-btn" @click="resetToDefaults">
            <svg
              viewBox="0 0 20 20"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M3 10a7 7 0 019-6.5M17 10a7 7 0 01-9 6.5" />
              <path d="M8 3L6 1 4 3M12 17l2 2 2-2" />
            </svg>
            Reset
          </button>
        </div>

        <div class="params-grid">
          <template x-for="field in fields" :key="field.id">
            <div class="param-card">
              <div class="param-header">
                <label :for="field.id" class="param-label">
                  <span class="label-icon" x-html="field.icon"></span>
                  <span x-text="field.label"></span>
                </label>
                <div class="param-value">
                  <span
                    class="value-main"
                    x-text="formatValue(field.value, field.isCurrency)"
                  ></span>
                  <span
                    class="value-unit"
                    x-show="!field.isCurrency"
                    x-text="field.unit"
                  ></span>
                </div>
              </div>

              <div class="param-controls">
                <input
                  :id="field.id"
                  type="number"
                  class="param-input"
                  x-model="field.value"
                  :min="field.min"
                  :max="field.max"
                  :step="field.step"
                  @input="handleParamChange"
                />

                <div class="slider-container">
                  <input
                    :id="field.id + 'Slider'"
                    type="range"
                    class="param-slider"
                    x-model="field.value"
                    :min="field.min"
                    :max="field.max"
                    :step="field.step"
                    @input="handleParamChange"
                  />
                </div>
              </div>

              <div class="param-range">
                <span x-text="formatValue(field.min, field.isCurrency)"></span>
                <span x-text="formatValue(field.max, field.isCurrency)"></span>
              </div>
            </div>
          </template>
        </div>
      </div>

      <!-- Action Button -->
      <button
        class="simulate-action"
        @click="runSimulation"
        :disabled="isCalculating"
      >
        <span class="action-content">
          <svg
            class="action-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            x-show="!isCalculating"
          >
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
          <span class="spinner-ring" x-show="isCalculating"></span>
          <span
            x-text="isCalculating ? 'Analyzing...' : 'Generate Projection'"
          ></span>
        </span>
      </button>
    </div>

    <!-- Right Panel - Results Dashboard -->
    <div class="dashboard-panel">
      <!-- Status Bar -->
      <div class="dashboard-status">
        <div class="status-left">
          <div class="status-badge" :class="statusType">
            <span class="status-dot"></span>
            <span x-text="statusMessage"></span>
          </div>
        </div>
        <div class="status-right">
          <div class="time-indicator">
            <svg
              viewBox="0 0 20 20"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="10" cy="10" r="9" />
              <path d="M10 5v5l3 2" />
            </svg>
            <span
              x-text="`${fields[3].value} Year${fields[3].value > 1 ? 's' : ''}`"
            ></span>
          </div>
        </div>
      </div>

      <!-- Main KPI -->
      <div class="kpi-hero">
        <div class="kpi-label-group">
          <h2>Projected Portfolio Value</h2>
          <div class="kpi-trend" :class="trendDirection">
            <svg
              viewBox="0 0 20 20"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M2 17L7 12L11 16L18 7" />
            </svg>
            <span x-text="trendValue"></span>
          </div>
        </div>
        <div class="kpi-number">
          <span class="kpi-currency">$</span>
          <span
            class="kpi-digits"
            x-text="formatLargeNumber(projectionData.median)"
          ></span>
        </div>
        <div class="kpi-range">
          <div class="range-item low">
            <span class="range-label">Conservative</span>
            <span
              class="range-value"
              x-text="formatCurrency(projectionData.worst)"
            ></span>
          </div>
          <div class="range-divider"></div>
          <div class="range-item high">
            <span class="range-label">Optimistic</span>
            <span
              class="range-value"
              x-text="formatCurrency(projectionData.best)"
            ></span>
          </div>
        </div>
      </div>

      <!-- Metrics Grid -->
      <!-- <div class="metrics-dashboard">
        <div
          class="metric-tile"
          :class="metric.trend"
          x-for="metric in displayMetrics"
          :key="metric.label"
        >
          <div class="tile-header">
            <span class="tile-label" x-text="metric.label"></span>
            <div class="tile-icon" x-html="metric.icon"></div>
          </div>
          <div class="tile-value" x-text="metric.value"></div>
          <div class="tile-footer" x-show="metric.description">
            <span x-text="metric.description"></span>
          </div>
        </div>
      </div> -->

      <!-- Chart Section -->
      <div class="chart-section">
        <div class="chart-header">
          <h3>Wealth Accumulation Timeline</h3>
          <div class="chart-filters">
            <button class="filter-btn active">1Y</button>
            <button class="filter-btn">5Y</button>
            <button class="filter-btn">Max</button>
          </div>
        </div>
        <div id="wealthVisualization" class="chart-container"></div>
        <div class="chart-legend">
          <div class="legend-entry">
            <span class="legend-color median"></span>
            <span>Median Projection</span>
          </div>
          <div class="legend-entry">
            <span class="legend-color best"></span>
            <span>Best Case (90th Percentile)</span>
          </div>
          <div class="legend-entry">
            <span class="legend-color worst"></span>
            <span>Worst Case (10th Percentile)</span>
          </div>
        </div>
      </div>

      <!-- Insights & Actions -->
      <div class="insights-section">
        <!-- AI Analysis -->
        <div class="analysis-card">
          <div class="analysis-header">
            <div class="ai-badge">
              <span class="ai-icon">✨</span>
              <span>AI Analysis</span>
            </div>
          </div>
          <div class="analysis-content">
            <template x-if="!isLoadingAnalysis">
              <p class="analysis-text" x-text="aiAnalysis"></p>
            </template>
            <template x-if="isLoadingAnalysis">
              <div class="analysis-loading">
                <div class="loading-wave">
                  <span></span><span></span><span></span><span></span>
                </div>
                <span>Generating insights...</span>
              </div>
            </template>
          </div>
        </div>

        <!-- Action Items -->
        <div
          class="actions-card"
          x-show="actionItems && actionItems.length > 0"
        >
          <div class="actions-header">
            <h4>Recommended Actions</h4>
            <span class="action-count" x-text="actionItems.length"></span>
          </div>
          <div class="actions-list">
            <template x-for="(action, idx) in actionItems" :key="idx">
              <div class="action-row">
                <div class="action-marker" x-text="idx + 1"></div>
                <div class="action-details">
                  <p x-text="action"></p>
                </div>
                <div class="action-arrow">
                  <svg
                    viewBox="0 0 20 20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M7 4l6 6-6 6" />
                  </svg>
                </div>
              </div>
            </template>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script
  defer
  src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"
></script>
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<script>
  document.addEventListener("alpine:init", () => {
    Alpine.data("wealthSimulator", () => ({
      strategy: "balanced",
      isCalculating: false,
      isLoadingAnalysis: false,
      statusType: "ready",
      statusMessage: "Ready for analysis",

      // Financial Data
      projectionData: {
        median: 0,
        best: 0,
        worst: 0,
        successRate: 0,
      },

      trendDirection: "positive",
      trendValue: "+0%",
      aiAnalysis:
        "Configure your parameters and generate a projection to receive personalized insights.",

      actionItems: [],

      // Configuration
      fields: [
        {
          id: "income",
          label: "Monthly Income",
          value: 4000,
          min: 0,
          max: 50000,
          step: 100,
          isCurrency: true,
          unit: "USD",
          icon: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="10" cy="10" r="8"/><path d="M10 5v10M7 8l3-3 3 3M7 12l3 3 3-3"/></svg>',
        },
        {
          id: "expenses",
          label: "Monthly Expenses",
          value: 2000,
          min: 0,
          max: 40000,
          step: 50,
          isCurrency: true,
          unit: "USD",
          icon: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="10" cy="10" r="8"/><path d="M10 15V5M7 12l3 3 3-3M7 8l3-3 3 3"/></svg>',
        },
        {
          id: "savings",
          label: "Current Portfolio",
          value: 30000,
          min: 0,
          max: 500000,
          step: 1000,
          isCurrency: true,
          unit: "USD",
          icon: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 10h14M5 14l-2-4 2-4M15 14l2-4-2-4"/><circle cx="10" cy="10" r="8"/></svg>',
        },
        {
          id: "years",
          label: "Time Horizon",
          value: 10,
          min: 1,
          max: 50,
          step: 1,
          isCurrency: false,
          unit: "years",
          icon: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="10" cy="10" r="9"/><path d="M10 4v6l3 2"/></svg>',
        },
      ],

      displayMetrics: [
        {
          label: "Monthly Contribution",
          value: "$2,000",
          trend: "neutral",
          icon: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 16l4-4 3 3 5-7"/></svg>',
          description: "From income surplus",
        },
        {
          label: "Success Probability",
          value: "0%",
          trend: "positive",
          icon: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="10" cy="10" r="8"/><path d="M6 10l3 3 5-6"/></svg>',
          description: "Achieving target",
        },
        {
          label: "Risk-Adjusted Return",
          value: "7.2%",
          trend: "positive",
          icon: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 10h16M10 2v16"/></svg>',
          description: "Annual projected",
        },
      ],

      // UI State
      riskLevel: 50,
      riskLabel: "Moderate",
      strategyLabel: "Balanced Growth",

      chart: null,
      updateTimer: null,

      // Lifecycle
      initialize() {
        this.$nextTick(() => {
          this.initChart();
          this.updateStrategyLabels();
          this.runSimulation();
        });
      },

      // Strategy Management
      setStrategy(type) {
        this.strategy = type;
        this.updateStrategyLabels();

        // Apply preset values
        const presets = {
          safe: { income: 3000, expenses: 1600, savings: 20000 },
          balanced: { income: 4000, expenses: 2000, savings: 30000 },
          aggressive: { income: 5000, expenses: 2500, savings: 50000 },
        };

        const preset = presets[type];
        if (preset) {
          this.fields[0].value = preset.income;
          this.fields[1].value = preset.expenses;
          this.fields[2].value = preset.savings;
        }

        this.runSimulation();
      },

      updateStrategyLabels() {
        const config = {
          safe: { risk: 25, riskLabel: "Conservative", label: "Safe Saver" },
          balanced: {
            risk: 50,
            riskLabel: "Moderate",
            label: "Balanced Growth",
          },
          aggressive: {
            risk: 85,
            riskLabel: "Growth",
            label: "Aggressive Builder",
          },
        };

        const cfg = config[this.strategy];
        this.riskLevel = cfg.risk;
        this.riskLabel = cfg.riskLabel;
        this.strategyLabel = cfg.label;
      },

      // Formatting Utilities
      formatValue(value, isCurrency) {
        if (!isCurrency) return value;
        return new Intl.NumberFormat("en-US", {
          style: "currency",
          currency: "USD",
          minimumFractionDigits: 0,
          maximumFractionDigits: 0,
        }).format(value);
      },

      formatCurrency(value) {
        return new Intl.NumberFormat("en-US", {
          style: "currency",
          currency: "USD",
          minimumFractionDigits: 0,
          maximumFractionDigits: 0,
        }).format(value);
      },

      formatLargeNumber(value) {
        if (value >= 1000000) {
          return (value / 1000000).toFixed(2) + "M";
        } else if (value >= 1000) {
          return (value / 1000).toFixed(1) + "K";
        }
        return value.toString();
      },

      // Chart Initialization
      initChart() {
        const element = document.querySelector("#wealthVisualization");
        if (!element) return;

        this.chart = new ApexCharts(element, {
          chart: {
            type: "area",
            height: 280,
            toolbar: { show: false },
            animations: {
              enabled: true,
              easing: "easeinout",
              speed: 800,
              animateGradually: { enabled: true, delay: 100 },
            },
            fontFamily: "Plus Jakarta Sans, sans-serif",
            background: "transparent",
          },
          stroke: {
            curve: "smooth",
            width: [3, 2, 2],
            dashArray: [0, 5, 5],
          },
          fill: {
            type: "gradient",
            gradient: {
              shadeIntensity: 0,
              opacityFrom: 0.15,
              opacityTo: 0.02,
              stops: [0, 90, 100],
            },
          },
          colors: ["#6366f1", "#10b981", "#ef4444"],
          series: [
            { name: "Median", data: [] },
            { name: "Best Case", data: [] },
            { name: "Worst Case", data: [] },
          ],
          xaxis: {
            categories: [],
            labels: { style: { colors: "#64748b", fontSize: "12px" } },
            axisBorder: { show: false },
            axisTicks: { show: false },
          },
          yaxis: {
            labels: {
              formatter: (val) => this.formatCurrency(val),
              style: { colors: "#64748b", fontSize: "12px" },
            },
            grid: {
              borderColor: "#e2e8f0",
              strokeDashArray: 4,
              xaxis: { lines: { show: true } },
            },
          },
          tooltip: {
            shared: true,
            intersect: false,
            y: { formatter: (val) => this.formatCurrency(val) },
          },
          legend: { show: false },
          grid: {
            show: true,
            borderColor: "#e2e8f0",
            strokeDashArray: 4,
            padding: { top: 0, right: 10, bottom: 0, left: 10 },
          },
        });

        this.chart.render();
      },

      // Event Handlers
      handleParamChange() {
        clearTimeout(this.updateTimer);
        this.updateTimer = setTimeout(() => this.runSimulation(), 300);
      },

      resetToDefaults() {
        this.setStrategy("balanced");
      },

      // Simulation Logic
      async runSimulation() {
        this.isCalculating = true;
        this.statusType = "calculating";
        this.statusMessage = "Processing...";

        const payload = {
          income: this.fields[0].value,
          expenses: this.fields[1].value,
          savings: this.fields[2].value,
          years: this.fields[3].value,
          strategy: this.strategy,
        };

        try {
          // Simulate API delay
          await new Promise((resolve) => setTimeout(resolve, 600));

          const result = this.calculateProjection(payload);
          this.updateDashboard(result);

          this.statusType = "success";
          this.statusMessage = "Analysis Complete";

          setTimeout(() => {
            this.statusType = "ready";
            this.statusMessage = "Ready";
          }, 2000);
        } catch (error) {
          console.error("Simulation error:", error);
          this.statusType = "error";
          this.statusMessage = "Calculation Failed";
        } finally {
          this.isCalculating = false;
        }
      },

      calculateProjection(payload) {
        const monthlySavings = Math.max(0, payload.income - payload.expenses);
        const yearlyContribution = monthlySavings * 12;

        const returnRates = {
          safe: { base: 0.04, volatility: 0.03 },
          balanced: { base: 0.07, volatility: 0.08 },
          aggressive: { base: 0.1, volatility: 0.15 },
        };

        const rate = returnRates[payload.strategy];

        let median = payload.savings;
        let best = payload.savings;
        let worst = payload.savings;

        const labels = [];
        const medianData = [];
        const bestData = [];
        const worstData = [];

        for (let year = 0; year <= payload.years; year++) {
          labels.push(`Y${year}`);
          medianData.push(Math.round(median));
          bestData.push(Math.round(best));
          worstData.push(Math.round(worst));

          median = median * (1 + rate.base) + yearlyContribution;
          best = best * (1 + rate.base + rate.volatility) + yearlyContribution;
          worst = Math.max(
            worst * (1 + rate.base - rate.volatility) + yearlyContribution,
            0,
          );
        }

        const finalMedian = medianData[medianData.length - 1];
        const finalBest = bestData[bestData.length - 1];
        const finalWorst = worstData[worstData.length - 1];

        const successRate = Math.min(
          98,
          60 +
            (payload.strategy === "safe"
              ? 25
              : payload.strategy === "balanced"
                ? 20
                : 15) +
            (monthlySavings / payload.income) * 20,
        );

        return {
          chart: {
            labels,
            median: medianData,
            best: bestData,
            worst: worstData,
          },
          summary: {
            median: finalMedian,
            best: finalBest,
            worst: finalWorst,
            successRate,
          },
          monthlySavings,
        };
      },

      updateDashboard(result) {
        // Update projection data
        this.projectionData = result.summary;

        // Calculate trend
        const initialInvestment = this.fields[2].value;
        const change =
          ((result.summary.median - initialInvestment) / initialInvestment) *
          100;
        this.trendValue = `${change > 0 ? "+" : ""}${change.toFixed(1)}%`;
        this.trendDirection =
          change > 20 ? "positive" : change > 0 ? "neutral" : "negative";

        // Update metrics
        const monthlyContribution = result.monthlySavings;
        this.displayMetrics[0].value = this.formatCurrency(monthlyContribution);
        this.displayMetrics[1].value = `${Math.round(result.summary.successRate)}%`;

        const annualReturn =
          this.strategy === "safe"
            ? "4.2%"
            : this.strategy === "balanced"
              ? "7.2%"
              : "10.5%";
        this.displayMetrics[2].value = annualReturn;

        // Update chart
        if (this.chart) {
          this.chart.updateOptions({
            xaxis: { categories: result.chart.labels },
          });
          this.chart.updateSeries([
            { name: "Median", data: result.chart.median },
            { name: "Best Case", data: result.chart.best },
            { name: "Worst Case", data: result.chart.worst },
          ]);
        }

        // Generate insights
        this.generateInsights(result);
      },

      generateInsights(result) {
        this.isLoadingAnalysis = true;

        setTimeout(() => {
          const monthlySavings = result.monthlySavings;
          const savingsRate = (
            (monthlySavings / this.fields[0].value) *
            100
          ).toFixed(1);
          const median = result.summary.median;
          const years = this.fields[3].value;

          // AI Analysis
          if (result.summary.successRate > 75) {
            this.aiAnalysis = `Excellent financial trajectory detected. With a ${savingsRate}% savings rate and ${this.strategy} strategy, your portfolio is projected to reach ${this.formatCurrency(median)} over ${years} years. The strong success probability of ${Math.round(result.summary.successRate)}% indicates robust portfolio construction. Consider optimizing tax efficiency through Roth conversions or municipal bonds for enhanced after-tax returns.`;
          } else if (result.summary.successRate > 50) {
            this.aiAnalysis = `Solid financial foundation with room for optimization. Your current ${savingsRate}% savings rate projects to ${this.formatCurrency(median)} over ${years} years with a ${Math.round(result.summary.successRate)}% success probability. Increasing monthly contributions by just 5% could add approximately ${this.formatCurrency(median * 0.15)} to your final portfolio value through compound growth.`;
          } else {
            this.aiAnalysis = `Your current trajectory requires strategic adjustments. With projected outcomes showing significant variance, consider increasing your savings rate from ${savingsRate}% to at least 20% of income. Even modest increases of $100-200 monthly can dramatically improve long-term outcomes through the power of compound returns over ${years} years.`;
          }

          // Action Items
          this.actionItems = [];

          if (parseFloat(savingsRate) < 20) {
            this.actionItems.push(
              `Increase savings rate from ${savingsRate}% to 20%+ for optimal wealth accumulation`,
            );
          }

          if (this.strategy === "safe" && years > 10) {
            this.actionItems.push(
              `Consider Balanced Growth strategy for potentially ${this.formatCurrency(median * 0.25)} additional returns over ${years} years`,
            );
          }

          if (this.fields[2].value < this.fields[0].value * 6) {
            this.actionItems.push(
              `Build emergency fund to ${this.formatCurrency(this.fields[0].value * 6)} (6 months expenses) before aggressive investing`,
            );
          }

          if (this.fields[1].value > this.fields[0].value * 0.6) {
            const targetExpense = this.fields[0].value * 0.5;
            this.actionItems.push(
              `Reduce monthly expenses by ${this.formatCurrency(this.fields[1].value - targetExpense)} to optimize savings rate`,
            );
          }

          const taxTip = this.strategy === "aggressive" ? "15-20%" : "10-15%";
          this.actionItems.push(
            `Maximize tax-advantaged accounts (401k, IRA, HSA) for estimated ${taxTip} improvement in after-tax returns`,
          );

          // Limit to 4 items
          this.actionItems = this.actionItems.slice(0, 4);

          this.isLoadingAnalysis = false;
        }, 800);
      },
    }));
  });
</script>

