<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script src="/libs/apexcharts/dist/apexcharts.min.js"></script>
<script>
  document.querySelector(".demoHint").addEventListener("click", () => {
    window.location.href = "/simulations";
  });
  let monteData = `<%- JSON.stringify(monteData) %>`;
  let monteDataParsed = JSON.parse(monteData);
  console.log(monteDataParsed);
  function runRunWayChart() {
    let options = {
      chart: {
        type: "line",
        height: 350,
        zoom: { enabled: false },
        animations: { enabled: true, speed: 800 },
      },
      stroke: {
        width: 2,
        curve: "smooth",
        opacity: 0.5,
      },
      fill: {
        opacity: 1,
      },
      series: monteDataParsed,
      tooltip: { shared: false },
      dataLabels: { enabled: false },
      markers: { size: 0 },
      xaxis: {
        title: { text: "Years from now" },
        categories: Array.from({ length: 21 }, (_, i) => i),
      },
      yaxis: {
        labels: { formatter: (val) => `$${val}` },
      },
    };

    new ApexCharts(document.querySelector(".liveChart"), options).render();
  }
  runRunWayChart();
</script>
