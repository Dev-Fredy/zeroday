<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
  (function () {
    // Enhanced chart rendering
    let monteData = `<%- JSON.stringify(monteData) %>`;
    let monteDataParsed;

    try {
      monteDataParsed = JSON.parse(monteData);
    } catch (e) {
      console.warn("Using enhanced sample data for demo preview");
      monteDataParsed = [
        {
          name: "Median (50th Percentile)",
          data: [
            20000, 25000, 31000, 38000, 45000, 54000, 63000, 72000, 83000,
            94000, 106000, 119000, 132000, 146000, 161000, 177000, 194000,
            212000, 231000, 251000, 272000,
          ],
        },
        {
          name: "Top 10% (Optimistic)",
          data: [
            20000, 27000, 36000, 46000, 58000, 71000, 86000, 102000, 120000,
            140000, 162000, 186000, 212000, 240000, 270000, 302000, 336000,
            372000, 410000, 450000, 492000,
          ],
        },
        {
          name: "Bottom 10% (Conservative)",
          data: [
            20000, 22000, 24000, 26000, 28000, 30000, 32000, 34000, 36000,
            38000, 40000, 42000, 44000, 46000, 48000, 50000, 52000, 54000,
            56000, 58000, 60000,
          ],
        },
      ];
    }

    function renderChart() {
      const chartEl = document.querySelector(".chart-wrapper");
      if (!chartEl) return;

      const options = {
        chart: {
          type: "line",
          height: 420,
          zoom: {
            enabled: true,
            type: "x",
            autoScaleYaxis: true,
          },
          animations: {
            enabled: true,
            speed: 800,
            animateGradually: { enabled: true, delay: 150 },
          },
          toolbar: {
            show: true,
            tools: {
              download: true,
              selection: true,
              zoom: true,
              zoomin: true,
              zoomout: true,
              pan: true,
              reset: true,
            },
          },
          fontFamily: "Inter, sans-serif",
          background: "transparent",
        },
        stroke: {
          width: [3, 2, 2],
          curve: "smooth",
          dashArray: [0, 5, 5],
        },
        colors: ["#2563eb", "#10b981", "#f97316"],
        fill: {
          type: ["solid", "gradient", "gradient"],
          gradient: {
            shade: "light",
            type: "vertical",
            shadeIntensity: 0.5,
            opacityFrom: 0.3,
            opacityTo: 0.05,
          },
        },
        series: monteDataParsed,
        tooltip: {
          shared: true,
          intersect: false,
          theme: "light",
          y: {
            formatter: (val) => {
              if (val >= 1000000) return "$" + (val / 1000000).toFixed(1) + "M";
              if (val >= 1000) return "$" + (val / 1000).toFixed(0) + "k";
              return "$" + val;
            },
          },
        },
        dataLabels: { enabled: false },
        markers: {
          size: 0,
          hover: { size: 6 },
          discrete: [
            {
              seriesIndex: 0,
              dataPointIndex: 20,
              size: 6,
              strokeColor: "#2563eb",
              fillColor: "#fff",
            },
          ],
        },
        grid: {
          borderColor: "#eef2f6",
          strokeDashArray: 4,
          padding: { top: 20, bottom: 10, left: 10, right: 10 },
        },
        xaxis: {
          title: {
            text: "Years from now",
            style: { fontWeight: 500, fontSize: "13px" },
          },
          categories: Array.from({ length: 21 }, (_, i) => `Year ${i}`),
          labels: {
            style: { fontSize: "12px" },
            formatter: (val) => val,
          },
          axisBorder: { show: false },
          axisTicks: { show: false },
        },
        yaxis: {
          title: {
            text: "Portfolio Value (USD)",
            style: { fontWeight: 500, fontSize: "13px" },
          },
          labels: {
            formatter: (val) => {
              if (val >= 1000000) return "$" + (val / 1000000).toFixed(1) + "M";
              if (val >= 1000) return "$" + (val / 1000).toFixed(0) + "k";
              return "$" + val;
            },
          },
        },
        legend: {
          position: "top",
          horizontalAlign: "center",
          offsetY: 0,
          fontSize: "13px",
          markers: { radius: 4 },
        },
      };

      const chart = new ApexCharts(chartEl, options);
      chart.render();

      window.addEventListener("resize", () => {
        if (chart && typeof chart.render === "function") {
          chart.render();
        }
      });
    }

    renderChart();

    // Enhanced demo hint click handler
    const demoHint = document.querySelector(".demoHint");
    if (demoHint) {
      demoHint.addEventListener("click", (e) => {
        if (e.target.closest("a")) return;
        window.location.href = "/simulations";
      });
    }

    // Animate stats on scroll
    const observerOptions = {
      threshold: 0.5,
      rootMargin: "0px",
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("animated");
        }
      });
    }, observerOptions);

    document.querySelectorAll(".stat-number").forEach((stat) => {
      observer.observe(stat);
    });
  })();
</script>
