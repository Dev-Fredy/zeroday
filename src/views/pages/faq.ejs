<main class="faq-detail-main">
    <!-- Breadcrumb Navigation -->
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol class="breadcrumb-list">
          <li class="breadcrumb-item">
            <a href="/">Home</a>
            <span class="separator">/</span>
          </li>
          <li class="breadcrumb-item">
            <a href="/faqs">FAQs</a>
            <span class="separator">/</span>
          </li>
          <% if (faq.category) { %>
          <li class="breadcrumb-item">
            <a href="/faqs?category=<%- encodeURIComponent(faq.category) %>">
              <%- faq.category %>
            </a>
            <span class="separator">/</span>
          </li>
          <% } %>
          <li class="breadcrumb-item active" aria-current="page">
            <%- faq.title.slice(0, 50) %>...
          </li>
        </ol>
      </nav>
    </div>

    <div class="container">
      <div class="faq-detail-layout">
        <!-- Main Content -->
        <article class="faq-article">
          <!-- Article Header -->
          <header class="article-header">
            <div class="article-meta-top">
              <span class="article-category">
                <span class="category-icon">📁</span>
                <a href="/faqs?category=<%- encodeURIComponent(faq.category) %>">
                  <%- faq.category || 'General' %>
                </a>
              </span>
              
              <span class="article-read-time">
                <span class="time-icon">📖</span>
                <% const readTime = Math.ceil((faq.content?.length) / 1500); %>
                <%- Math.max(readTime, 2) %> min read
              </span>
              
              <span class="article-date">
                <span class="date-icon">📅</span>
                <% if (faq.updatedAt) { %>
                  Updated <%- new Date(faq.updatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                <% } else { %>
                  Published <%- new Date(faq.createdAt || Date.now()).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                <% } %>
              </span>
            </div>
            
            <h1 class="article-title"><%- faq.title %></h1>
            
            <div class="article-excerpt">
              <p><%- faq.description %></p>
            </div>
            
            <!-- Featured Image -->
            <% if (faq.featuredUrl) { %>
            <figure class="article-featured-image">
              <img 
                src="<%- faq.featuredUrl %>" 
                alt="<%- faq.title %>"
                loading="eager"
                onerror="this.style.display='none'"
              />
              <% if (faq.imageCaption) { %>
              <figcaption><%- faq.imageCaption %></figcaption>
              <% } %>
            </figure>
            <% } %>
          </header>
          
          <!-- Table of Contents (Auto-generated) -->
          <nav class="article-toc card">
            <div class="toc-header">
              <span class="toc-icon">📑</span>
              <h2 class="toc-title">Table of Contents</h2>
              <button class="toc-toggle" onclick="toggleTOC()" aria-label="Toggle table of contents">
                <span class="toggle-icon">▼</span>
              </button>
            </div>
            <div class="toc-content" id="tableOfContents">
              <!-- Generated by JavaScript -->
            </div>
          </nav>
          
          <!-- Article Content -->
          <div class="article-content">
            <%- faq.content || faq.description %>
          </div>
          
          <!-- Article Footer -->
          <footer class="article-footer">
            <!-- Helpful Vote -->
            <div class="article-feedback card">
              <h3 class="feedback-title">Was this article helpful?</h3>
              <div class="feedback-buttons">
                <button class="feedback-btn" onclick="submitFeedback(true)">
                  <span class="feedback-icon">👍</span>
                  Yes
                </button>
                <button class="feedback-btn" onclick="submitFeedback(false)">
                  <span class="feedback-icon">👎</span>
                  No
                </button>
              </div>
              <div class="feedback-message" id="feedbackMessage" style="display: none;">
                Thank you for your feedback!
              </div>
            </div>
            
            <!-- Share Buttons -->
            <div class="article-share">
              <span class="share-label">Share this article:</span>
              <div class="share-buttons">
                <button class="share-btn" onclick="shareArticle('twitter')" aria-label="Share on Twitter">
                  <span>𝕏</span>
                </button>
                <button class="share-btn" onclick="shareArticle('linkedin')" aria-label="Share on LinkedIn">
                  <span>in</span>
                </button>
                <button class="share-btn" onclick="shareArticle('facebook')" aria-label="Share on Facebook">
                  <span>f</span>
                </button>
                <button class="share-btn" onclick="copyLink()" aria-label="Copy link">
                  <span>🔗</span>
                </button>
              </div>
              <span class="copy-confirmation" id="copyConfirmation">Link copied!</span>
            </div>
            
            <!-- Article Navigation -->
            <nav class="article-navigation">
              <% if (prevFaq) { %>
              <a href="/faqs/<%- prevFaq.slug %>_<%- prevFaq.id %>" class="nav-link prev">
                <span class="nav-label">← Previous</span>
                <span class="nav-title"><%- prevFaq.title %></span>
              </a>
              <% } else { %>
              <div></div>
              <% } %>
              
              <% if (nextFaq) { %>
              <a href="/faqs/<%- nextFaq.slug %>_<%- nextFaq.id %>" class="nav-link next">
                <span class="nav-label">Next →</span>
                <span class="nav-title"><%- nextFaq.title %></span>
              </a>
              <% } %>
            </nav>
          </footer>
        </article>
        
        <!-- Sidebar -->
        <aside class="faq-sidebar">
          <!-- Related Articles -->
          <% if (related && related.length > 0) { %>
          <div class="sidebar-section card">
            <h3 class="sidebar-title">
              <span class="title-icon">🔗</span>
              Related Articles
            </h3>
            <ul class="related-list">
              <% related.forEach((item) => { %>
              <li class="related-item">
                <a href="/faqs/<%- item.slug %>_<%- item.id %>" class="related-link">
                  <% if (item.featuredUrl) { %>
                  <img 
                    src="<%- item.featuredUrl %>" 
                    alt="<%- item.title %>"
                    class="related-image"
                    loading="lazy"
                  />
                  <% } %>
                  <div class="related-content">
                    <h4 class="related-title"><%- item.title %></h4>
                    <p class="related-excerpt"><%- item.description.slice(0, 60) %>...</p>
                  </div>
                </a>
              </li>
              <% }) %>
            </ul>
          </div>
          <% } %>
          
          <!-- In This Category -->
          <div class="sidebar-section card">
            <h3 class="sidebar-title">
              <span class="title-icon">📚</span>
              More in <%- faq.category %>
            </h3>
            <ul class="category-list">
              <% if (categoryFaqs && categoryFaqs.length > 0) { %>
                <% categoryFaqs.slice(0, 5).forEach((item) => { %>
                  <% if (item.id !== faq.id) { %>
                  <li class="category-item">
                    <a href="/faqs/<%- item.slug %>_<%- item.id %>">
                      <span class="item-bullet">•</span>
                      <%- item.title %>
                    </a>
                  </li>
                  <% } %>
                <% }) %>
              <% } %>
            </ul>
            <a href="/faqs?category=<%- encodeURIComponent(faq.category) %>" class="view-all-link">
              View all in this category →
            </a>
          </div>
          
          <!-- Still Need Help -->
          <div class="sidebar-section card card-highlight">
            <div class="help-content">
              <span class="help-icon">💬</span>
              <h3 class="help-title">Still need help?</h3>
              <p class="help-text">
                Our support team is ready to assist you with any questions.
              </p>
              <a href="/contact" class="btn btn-primary btn-block">
                Contact Support
              </a>
              <p class="help-footer">
                <span class="response-time">⚡ Usually replies within 2 hours</span>
              </p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>


  <script>
    // Table of Contents Generator
    function generateTableOfContents() {
      const content = document.querySelector('.article-content');
      const toc = document.getElementById('tableOfContents');
      if (!content || !toc) return;
      
      const headings = content.querySelectorAll('h2, h3');
      if (headings.length === 0) {
        document.querySelector('.article-toc').style.display = 'none';
        return;
      }
      
      const tocList = document.createElement('ul');
      tocList.className = 'toc-list';
      
      headings.forEach((heading, index) => {
        const id = `heading-${index}`;
        heading.id = id;
        
        const listItem = document.createElement('li');
        listItem.className = `toc-item toc-${heading.tagName.toLowerCase()}`;
        
        const link = document.createElement('a');
        link.href = `#${id}`;
        link.textContent = heading.textContent;
        link.addEventListener('click', (e) => {
          e.preventDefault();
          heading.scrollIntoView({ behavior: 'smooth' });
        });
        
        listItem.appendChild(link);
        tocList.appendChild(listItem);
      });
      
      toc.appendChild(tocList);
    }
    
    // Toggle Table of Contents
    function toggleTOC() {
      const toc = document.getElementById('tableOfContents');
      const toggle = document.querySelector('.toggle-icon');
      
      if (toc.style.display === 'none') {
        toc.style.display = 'block';
        toggle.textContent = '▲';
      } else {
        toc.style.display = 'none';
        toggle.textContent = '▼';
      }
    }
    
    // Submit Feedback
    function submitFeedback(isHelpful) {
      const message = document.getElementById('feedbackMessage');
      const buttons = document.querySelectorAll('.feedback-btn');
      
      buttons.forEach(btn => btn.disabled = true);
      message.style.display = 'block';
      
      // Send to analytics/backend
      fetch('/api/faq-feedback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          faqId: '<%- faq.id %>',
          helpful: isHelpful
        })
      }).catch(console.error);
      
      setTimeout(() => {
        message.style.display = 'none';
      }, 3000);
    }
    
    // Share Article
    function shareArticle(platform) {
      const url = encodeURIComponent(window.location.href);
      const title = encodeURIComponent('<%- faq.title %>');
      
      let shareUrl = '';
      switch(platform) {
        case 'twitter':
          shareUrl = `https://twitter.com/intent/tweet?url=${url}&text=${title}`;
          break;
        case 'linkedin':
          shareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${url}`;
          break;
        case 'facebook':
          shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
          break;
      }
      
      if (shareUrl) {
        window.open(shareUrl, '_blank', 'width=600,height=400');
      }
    }
    
    // Copy Link
    function copyLink() {
      navigator.clipboard?.writeText(window.location.href).then(() => {
        const confirmation = document.getElementById('copyConfirmation');
        confirmation.style.display = 'inline';
        setTimeout(() => {
          confirmation.style.display = 'none';
        }, 2000);
      });
    }
    
    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      generateTableOfContents();
      
      // Highlight code blocks if any
      if (typeof Prism !== 'undefined') {
        Prism.highlightAll();
      }
    });
  </script>