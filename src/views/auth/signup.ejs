<main class="auth-main">
  <div class="auth-container">
    <!-- Back to Home -->
    <a href="/" class="auth-back-link">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      Back to Home
    </a>

    <!-- Auth Card -->
    <div class="auth-card auth-card-large">
      <!-- Brand Section -->
      <div class="auth-brand">
        <a href="/" class="auth-logo">
          <img src="/Images/ZeroDayFinance.png" alt="Zero Day Finance" />
        </a>
        <h1 class="auth-title">Create your account</h1>
        <p class="auth-subtitle">
          Start your financial journey today — it's free forever
        </p>
      </div>

      <!-- Social Sign Up -->
      <div class="social-login">
        <button
          type="button"
          class="social-btn google"
          onclick="socialSignup('google')"
        >
          <svg width="20" height="20" viewBox="0 0 24 24">
            <path
              fill="#4285F4"
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
            />
            <path
              fill="#34A853"
              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
            />
            <path
              fill="#FBBC05"
              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
            />
            <path
              fill="#EA4335"
              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
            />
          </svg>
          <span>Sign up with Google</span>
        </button>
      </div>

      <!-- Divider -->
      <div class="auth-divider">
        <span class="divider-text">or sign up with email</span>
      </div>

      <!-- Sign Up Form -->
      <form class="auth-form jsSignupForm" novalidate>
        <!-- Name Row -->
        <div class="form-row">
          <div class="form-group">
            <label for="first_name" class="form-label">First Name</label>
            <div class="input-wrapper">
              <span class="input-icon">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                >
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                </svg>
              </span>
              <input
                type="text"
                id="first_name"
                name="first_name"
                class="form-input jsFirstName"
                placeholder="John"
                autocomplete="given-name"
                required
              />
            </div>
            <div class="form-error jsFirstNameError"></div>
          </div>

          <div class="form-group">
            <label for="last_name" class="form-label">Last Name</label>
            <div class="input-wrapper">
              <span class="input-icon">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                >
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                </svg>
              </span>
              <input
                type="text"
                id="last_name"
                name="last_name"
                class="form-input jsLastName"
                placeholder="Doe"
                autocomplete="family-name"
                required
              />
            </div>
            <div class="form-error jsLastNameError"></div>
          </div>
        </div>

        <!-- Phone -->
        <div class="form-group">
          <label for="phone" class="form-label">Phone Number (Optional)</label>
          <div class="input-wrapper">
            <span class="input-icon">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
              >
                <rect x="5" y="2" width="14" height="20" rx="2" ry="2" />
                <line x1="12" y1="18" x2="12.01" y2="18" />
              </svg>
            </span>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="form-input jsPhone"
              placeholder="+1 (555) 000-0000"
              autocomplete="tel"
            />
          </div>
          <div class="form-error jsPhoneError"></div>
        </div>

        <!-- Email -->
        <div class="form-group">
          <label for="email" class="form-label">Email Address</label>
          <div class="input-wrapper">
            <span class="input-icon">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
              >
                <path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                />
                <polyline points="22,6 12,13 2,6" />
              </svg>
            </span>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input jsEmail"
              placeholder="you@example.com"
              autocomplete="email"
              required
            />
          </div>
          <div class="form-error jsEmailError"></div>
        </div>

        <!-- Password -->
        <div class="form-group">
          <label for="password" class="form-label">Password</label>
          <div class="input-wrapper">
            <span class="input-icon">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
              >
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
            </span>
            <input
              type="password"
              id="password"
              name="password"
              class="form-input jsPassword"
              placeholder="Create a strong password"
              autocomplete="new-password"
              required
            />
            <button
              type="button"
              class="password-toggle jsPasswordToggle"
              aria-label="Toggle password visibility"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
              >
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            </button>
          </div>
          <!-- Password Strength Meter -->
          <div
            class="password-strength jsPasswordStrength"
            style="display: none"
          >
            <div class="strength-bar">
              <div class="strength-fill jsStrengthFill"></div>
            </div>
            <span class="strength-text jsStrengthText">Weak</span>
          </div>
          <div class="password-requirements">
            <span class="requirement jsLengthReq">✓ 8+ characters</span>
            <span class="requirement jsUpperReq">✓ Uppercase letter</span>
            <span class="requirement jsNumberReq">✓ Number</span>
            <span class="requirement jsSpecialReq">✓ Special character</span>
          </div>
          <div class="form-error jsPasswordError"></div>
        </div>

        <!-- Confirm Password -->
        <div class="form-group">
          <label for="confirmPassword" class="form-label"
            >Confirm Password</label
          >
          <div class="input-wrapper">
            <span class="input-icon">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
              >
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
            </span>
            <input
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              class="form-input jsConfirmPassword"
              placeholder="Confirm your password"
              autocomplete="new-password"
              required
            />
            <span
              class="password-match-icon jsPasswordMatch"
              style="display: none"
              >✓</span
            >
          </div>
          <div class="form-error jsConfirmPasswordError"></div>
        </div>

        <!-- Terms Agreement -->
        <div class="form-checkbox">
          <label class="checkbox-label">
            <input type="checkbox" class="checkbox-input jsTerms" required />
            <span class="checkbox-custom"></span>
            <span class="checkbox-text">
              I agree to the
              <a href="/terms" target="_blank" class="terms-link"
                >Terms of Service</a
              >
              and
              <a href="/privacy" target="_blank" class="terms-link"
                >Privacy Policy</a
              >
            </span>
          </label>
          <div class="form-error jsTermsError"></div>
        </div>

        <!-- Newsletter Opt-in -->
        <div class="form-checkbox">
          <label class="checkbox-label">
            <input
              type="checkbox"
              class="checkbox-input jsNewsletter"
              checked
            />
            <span class="checkbox-custom"></span>
            <span class="checkbox-text">
              Send me weekly financial tips and insights
            </span>
          </label>
        </div>

        <!-- General Error Message -->
        <div
          class="form-error form-error-general jsFormError"
          style="display: none"
        ></div>

        <!-- Submit Button -->
        <button
          type="submit"
          class="btn btn-primary btn-large btn-block jsSignUp"
        >
          <span class="btn-text">Create Free Account</span>
          <span class="btn-spinner" style="display: none"></span>
        </button>
      </form>

      <!-- Login Link -->
      <div class="auth-footer">
        <p class="auth-footer-text">
          Already have an account?
          <a href="/auth/login" class="auth-link">Sign in</a>
        </p>
      </div>
    </div>

    <!-- Trust Badges -->
  </div>
</main>

<script>
  (function () {
    "use strict";

    // DOM Elements
    const form = document.querySelector(".jsSignupForm");
    const firstNameInput = document.querySelector(".jsFirstName");
    const lastNameInput = document.querySelector(".jsLastName");
    const phoneInput = document.querySelector(".jsPhone");
    const emailInput = document.querySelector(".jsEmail");
    const passwordInput = document.querySelector(".jsPassword");
    const confirmPasswordInput = document.querySelector(".jsConfirmPassword");
    const termsCheckbox = document.querySelector(".jsTerms");
    const signupBtn = document.querySelector(".jsSignUp");
    const formError = document.querySelector(".jsFormError");
    const passwordToggle = document.querySelector(".jsPasswordToggle");

    // Password strength elements
    const strengthMeter = document.querySelector(".jsPasswordStrength");
    const strengthFill = document.querySelector(".jsStrengthFill");
    const strengthText = document.querySelector(".jsStrengthText");
    const lengthReq = document.querySelector(".jsLengthReq");
    const upperReq = document.querySelector(".jsUpperReq");
    const numberReq = document.querySelector(".jsNumberReq");
    const specialReq = document.querySelector(".jsSpecialReq");
    const passwordMatch = document.querySelector(".jsPasswordMatch");

    let isSubmitting = false;

    // Validation functions
    function isValidEmail(email) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    function isValidPhone(phone) {
      if (!phone) return true; // Optional
      return /^[\d\s\+\-\(\)]{10,}$/.test(phone);
    }

    function checkPasswordStrength(password) {
      let strength = 0;

      if (password.length >= 8) strength++;
      if (/[A-Z]/.test(password)) strength++;
      if (/[0-9]/.test(password)) strength++;
      if (/[^A-Za-z0-9]/.test(password)) strength++;

      return {
        score: strength,
        maxScore: 4,
        percentage: (strength / 4) * 100,
      };
    }

    // Update password strength UI
    function updatePasswordStrength(password) {
      if (!password) {
        strengthMeter.style.display = "none";
        return;
      }

      strengthMeter.style.display = "block";
      const strength = checkPasswordStrength(password);

      // Update bar
      strengthFill.style.width = strength.percentage + "%";

      if (strength.score <= 1) {
        strengthFill.style.background = "#ef4444";
        strengthText.textContent = "Weak";
      } else if (strength.score === 2) {
        strengthFill.style.background = "#f59e0b";
        strengthText.textContent = "Fair";
      } else if (strength.score === 3) {
        strengthFill.style.background = "#3b82f6";
        strengthText.textContent = "Good";
      } else {
        strengthFill.style.background = "#10b981";
        strengthText.textContent = "Strong";
      }

      // Update requirements
      lengthReq.classList.toggle("met", password.length >= 8);
      upperReq.classList.toggle("met", /[A-Z]/.test(password));
      numberReq.classList.toggle("met", /[0-9]/.test(password));
      specialReq.classList.toggle("met", /[^A-Za-z0-9]/.test(password));
    }

    // Check password match
    function checkPasswordMatch() {
      const password = passwordInput.value;
      const confirm = confirmPasswordInput.value;

      if (confirm && password === confirm) {
        passwordMatch.style.display = "flex";
        confirmPasswordInput.classList.remove("error");
        confirmPasswordInput.classList.add("success");
        return true;
      } else {
        passwordMatch.style.display = "none";
        if (confirm) {
          confirmPasswordInput.classList.add("error");
          confirmPasswordInput.classList.remove("success");
        }
        return false;
      }
    }

    // Field error handling
    function showFieldError(input, errorEl, message) {
      input.classList.add("error");
      if (errorEl) {
        errorEl.textContent = message;
        errorEl.style.display = "block";
      }
    }

    function clearFieldError(input, errorEl) {
      input.classList.remove("error");
      if (errorEl) {
        errorEl.textContent = "";
        errorEl.style.display = "none";
      }
    }

    // Validate entire form
    function validateForm() {
      let isValid = true;

      // First Name
      if (!firstNameInput.value.trim()) {
        showFieldError(
          firstNameInput,
          document.querySelector(".jsFirstNameError"),
          "First name is required",
        );
        isValid = false;
      } else {
        clearFieldError(
          firstNameInput,
          document.querySelector(".jsFirstNameError"),
        );
      }

      // Last Name
      if (!lastNameInput.value.trim()) {
        showFieldError(
          lastNameInput,
          document.querySelector(".jsLastNameError"),
          "Last name is required",
        );
        isValid = false;
      } else {
        clearFieldError(
          lastNameInput,
          document.querySelector(".jsLastNameError"),
        );
      }

      // Phone (optional but validate if provided)
      if (phoneInput.value && !isValidPhone(phoneInput.value)) {
        showFieldError(
          phoneInput,
          document.querySelector(".jsPhoneError"),
          "Please enter a valid phone number",
        );
        isValid = false;
      } else {
        clearFieldError(phoneInput, document.querySelector(".jsPhoneError"));
      }

      // Email
      if (!emailInput.value.trim()) {
        showFieldError(
          emailInput,
          document.querySelector(".jsEmailError"),
          "Email is required",
        );
        isValid = false;
      } else if (!isValidEmail(emailInput.value)) {
        showFieldError(
          emailInput,
          document.querySelector(".jsEmailError"),
          "Please enter a valid email address",
        );
        isValid = false;
      } else {
        clearFieldError(emailInput, document.querySelector(".jsEmailError"));
      }

      // Password
      const password = passwordInput.value;
      if (!password) {
        showFieldError(
          passwordInput,
          document.querySelector(".jsPasswordError"),
          "Password is required",
        );
        isValid = false;
      } else if (password.length < 8) {
        showFieldError(
          passwordInput,
          document.querySelector(".jsPasswordError"),
          "Password must be at least 8 characters",
        );
        isValid = false;
      } else {
        const strength = checkPasswordStrength(password);
        if (strength.score < 2) {
          showFieldError(
            passwordInput,
            document.querySelector(".jsPasswordError"),
            "Please use a stronger password",
          );
          isValid = false;
        } else {
          clearFieldError(
            passwordInput,
            document.querySelector(".jsPasswordError"),
          );
        }
      }

      // Confirm Password
      if (!confirmPasswordInput.value) {
        showFieldError(
          confirmPasswordInput,
          document.querySelector(".jsConfirmPasswordError"),
          "Please confirm your password",
        );
        isValid = false;
      } else if (password !== confirmPasswordInput.value) {
        showFieldError(
          confirmPasswordInput,
          document.querySelector(".jsConfirmPasswordError"),
          "Passwords do not match",
        );
        isValid = false;
      } else {
        clearFieldError(
          confirmPasswordInput,
          document.querySelector(".jsConfirmPasswordError"),
        );
      }

      // Terms
      if (!termsCheckbox.checked) {
        showFieldError(
          termsCheckbox.closest(".form-checkbox"),
          document.querySelector(".jsTermsError"),
          "You must agree to the terms",
        );
        isValid = false;
      } else {
        clearFieldError(
          termsCheckbox.closest(".form-checkbox"),
          document.querySelector(".jsTermsError"),
        );
      }

      return isValid;
    }

    // Show general error
    function showGeneralError(message) {
      if (formError) {
        formError.textContent = message;
        formError.style.display = "block";
      }
    }

    // Set loading state
    function setLoading(isLoading) {
      const btnText = signupBtn.querySelector(".btn-text");
      const btnSpinner = signupBtn.querySelector(".btn-spinner");

      isSubmitting = isLoading;
      signupBtn.disabled = isLoading;

      if (isLoading) {
        btnText.style.opacity = "0.5";
        btnSpinner.style.display = "inline-block";
      } else {
        btnText.style.opacity = "1";
        btnSpinner.style.display = "none";
      }
    }

    // Handle form submission
    async function handleSubmit(e) {
      e.preventDefault();

      if (isSubmitting) return;

      // Hide general error
      if (formError) formError.style.display = "none";

      // Validate
      if (!validateForm()) {
        return;
      }

      // Set loading
      setLoading(true);

      // Prepare data
      const data = {
        first_name: firstNameInput.value.trim(),
        last_name: lastNameInput.value.trim(),
        phone: phoneInput.value.trim() || null,
        email: emailInput.value.trim(),
        password: passwordInput.value,
        newsletter: document.querySelector(".jsNewsletter")?.checked || false,
      };

      try {
        const response = await fetch("/auth/signup", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (result.success === true) {
          // Success
          const btnText = signupBtn.querySelector(".btn-text");
          btnText.textContent = "✓ Account Created!";
          signupBtn.style.background = "var(--color-success)";

          setTimeout(() => {
            window.location.href = "/auth/login?welcome=true";
          }, 1000);
        } else {
          // Error
          let errorMessage = result.message || "Failed to create account";

          if (response.status === 409) {
            errorMessage = "An account with this email already exists";
          } else if (response.status === 400) {
            errorMessage = result.message || "Please check your information";
          }

          showGeneralError(errorMessage);
          setLoading(false);
        }
      } catch (error) {
        console.error("Signup error:", error);
        showGeneralError("Network error. Please try again.");
        setLoading(false);
      }
    }

    // Setup event listeners
    function setupListeners() {
      // Form submission
      form.addEventListener("submit", handleSubmit);

      // Password strength
      passwordInput.addEventListener("input", (e) => {
        updatePasswordStrength(e.target.value);
        if (confirmPasswordInput.value) {
          checkPasswordMatch();
        }
      });

      // Password match
      confirmPasswordInput.addEventListener("input", checkPasswordMatch);

      // Clear errors on input
      firstNameInput.addEventListener("input", () =>
        clearFieldError(
          firstNameInput,
          document.querySelector(".jsFirstNameError"),
        ),
      );
      lastNameInput.addEventListener("input", () =>
        clearFieldError(
          lastNameInput,
          document.querySelector(".jsLastNameError"),
        ),
      );
      phoneInput.addEventListener("input", () =>
        clearFieldError(phoneInput, document.querySelector(".jsPhoneError")),
      );
      emailInput.addEventListener("input", () =>
        clearFieldError(emailInput, document.querySelector(".jsEmailError")),
      );

      // Password toggle
      if (passwordToggle) {
        passwordToggle.addEventListener("click", () => {
          const type = passwordInput.type === "password" ? "text" : "password";
          passwordInput.type = type;

          const svg = passwordToggle.querySelector("svg");
          if (type === "text") {
            svg.innerHTML = `
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                <line x1="1" y1="1" x2="23" y2="23"/>
              `;
          } else {
            svg.innerHTML = `
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              `;
          }
        });
      }
    }

    // Social signup
    window.socialSignup = function (provider) {
      window.location.href = `/auth/${provider}/signup`;
    };

    // Initialize
    setupListeners();
    firstNameInput.focus();
  })();
</script>
